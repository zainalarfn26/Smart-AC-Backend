# ==========================================
# Konfigurasi Database MySQL
# ==========================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=db_smart_ac

# ==========================================
# Konfigurasi MQTT Broker
# ==========================================
MQTT_BROKER=mqtt://broker.emqx.io
MQTT_PORT=1883

# ==========================================
# Konfigurasi Server
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# Konfigurasi JWT (Autentikasi)
# ==========================================
JWT_SECRET=GANTI_DENGAN_SECRET_KEY_YANG_KUAT_DAN_RANDOM
JWT_EXPIRES_IN=7d

# ==========================================
# Konfigurasi CORS
# ==========================================
# Biarkan * untuk development, ganti ke URL frontend untuk production
# Contoh: http://localhost:8100 (Ionic dev server)
# Bisa lebih dari satu origin dengan koma, contoh:
# CORS_ORIGIN=http://localhost:8100,https://app.smartac.com
CORS_ORIGIN=*
